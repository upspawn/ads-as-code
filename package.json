{
  "name": "@upspawn/ads",
  "version": "0.1.0",
  "description": "Pulumi-style declarative ad campaign management in TypeScript",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai": {
      "bun": "./src/ai/index.ts",
      "import": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts"
    }
  },
  "bin": {
    "ads": "./cli/index.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "cli",
    "dist",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts src/ai/index.ts --outdir dist --splitting --target bun --format esm --packages external && tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "keywords": ["google-ads", "facebook-ads", "infrastructure-as-code", "ads", "campaign-management"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/upspawn/ads-as-code.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "ai": "^6.0.116",
    "google-ads-api": "^23.0.0",
    "stream-chain": "^3.4.1",
    "stream-json": "^1.9.1",
    "zod": "^4.3.6"
  },
  "trustedDependencies": [
    "protobufjs"
  ]
}
